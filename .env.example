# ============================================
# Gemini Image MCP Server - 環境変数設定
# ============================================

# ── 認証モード（必須）──
# "gemini_key" : 各ユーザーが Bearer Token で自分の Gemini API Key を渡す（デフォルト）
# "api_key"    : MCP_API_KEY でサーバーへのアクセスを制限 + 組織の Gemini API Key を固定使用
AUTH_MODE=gemini_key

# ── Gemini API キー ──
# AUTH_MODE=api_key の場合は必須（組織の Gemini API Key を固定設定）
# AUTH_MODE=gemini_key の場合は不要（各ユーザーが Bearer で渡す）
# https://aistudio.google.com/apikey で取得
# GEMINI_API_KEY=AIzaSy...

# ── MCP API キー ──
# AUTH_MODE=api_key の場合は必須
# 任意の文字列を設定し、MCPクライアントの Bearer Token としてこの値を指定
# MCP_API_KEY=your-secret-api-key-here
